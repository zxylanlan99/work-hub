## 附录 B：数据库部署与运维

> 本附录将 §2.9 索引策略和 §11.2 安全规则转化为可执行脚本，补充数据生命周期管理和部署检查清单。

### B.1 索引创建脚本

以下脚本使用 CloudBase JS SDK 创建所有索引。在 CloudBase 云函数或本地 Node.js 环境中执行。

```js
// scripts/create-indexes.js
// 使用 CloudBase JS SDK 创建所有集合的索引
// 前提：CloudBase 环境已初始化，集合已存在

const tcb = require('@cloudbase/node-sdk');
const app = tcb.init({ env: 'your-env-id' });
const db = app.database();

async function createIndexes() {
  const indexDefs = [
    // ===== 全局：所有集合的 _openid 单字段索引 =====
    ...['goals', 'milestones', 'tasks', 'categories', 'knowledge_items',
       'chats', 'messages', 'review_cards', 'review_history',
       'output_docs', 'user_settings', 'scraps', 'news_items'
    ].map(coll => ({
      collection: coll,
      name: `${coll}_openid`,
      keys: [{ name: '_openid', direction: '1' }],
      unique: false
    })),

    // ===== 复合索引 =====
    { collection: 'review_cards',  name: 'cards_today',
      keys: [{ name: '_openid', direction: '1' }, { name: 'nextReview', direction: '1' }, { name: 'mastery', direction: '1' }] },
    { collection: 'milestones',    name: 'ms_goal_sort',
      keys: [{ name: 'goalId', direction: '1' }, { name: 'sort', direction: '1' }] },
    { collection: 'tasks',         name: 'task_ms_sort',
      keys: [{ name: 'milestoneId', direction: '1' }, { name: 'sort', direction: '1' }] },
    { collection: 'messages',      name: 'msg_chat_time',
      keys: [{ name: 'chatId', direction: '1' }, { name: 'createdAt', direction: '-1' }] },
    { collection: 'knowledge_items', name: 'ki_del',
      keys: [{ name: '_openid', direction: '1' }, { name: 'isDeleted', direction: '1' }] },
    { collection: 'news_items',    name: 'news_read',
      keys: [{ name: '_openid', direction: '1' }, { name: 'hasRead', direction: '1' }] },

    // ===== 单字段查询索引 =====
    { collection: 'goals',         name: 'goal_status',
      keys: [{ name: 'status', direction: '1' }] },
    { collection: 'knowledge_items', name: 'ki_cat',
      keys: [{ name: 'categoryId', direction: '1' }] },
    { collection: 'review_cards',  name: 'card_ki',
      keys: [{ name: 'knowledgeItemId', direction: '1' }] },
    { collection: 'review_history', name: 'rh_card',
      keys: [{ name: 'cardId', direction: '1' }] },
    { collection: 'output_docs',   name: 'od_status',
      keys: [{ name: 'status', direction: '1' }] },
    { collection: 'scraps',        name: 'scrap_status',
      keys: [{ name: 'status', direction: '1' }] },
    { collection: 'chats',         name: 'chat_update',
      keys: [{ name: 'updatedAt', direction: '-1' }] },
  ];

  for (const def of indexDefs) {
    try {
      await db.collection(def.collection).createIndex({
        name: def.name,
        keys: def.keys,
        ...(def.unique !== undefined ? { unique: def.unique } : {})
      });
      console.log(`  ✓ ${def.collection}.${def.name}`);
    } catch (e) {
      if (e.code === 'ResourceAlreadyExists') {
        console.log(`  - ${def.collection}.${def.name} (已存在)`);
      } else {
        console.error(`  ✗ ${def.collection}.${def.name}: ${e.message}`);
      }
    }
  }
}

createIndexes()
  .then(() => { console.log('\n索引创建完成'); process.exit(0); })
  .catch(e => { console.error(e); process.exit(1); });
```

### B.2 逐集合差异化安全规则

§11.2 的通用规则（`auth.openid == doc._openid`）适用于大多数场景，以下集合需差异化配置：

#### B.2.1 保持通用规则的集合（7 个）

| 集合 | 规则 | 理由 |
|------|------|------|
| goals | 通用规则 | 个人学习目标 |
| milestones | 通用规则 | 附属于目标 |
| tasks | 通用规则 | 附属于里程碑 |
| review_cards | 通用规则 | 个人复习卡片 |
| review_history | 通用规则 | 个人复习记录 |
| output_docs | 通用规则 | 个人输出文档 |
| scraps | 通用规则 | 个人灵感碎片 |

#### B.2.2 需要增强规则的集合（6 个）

**categories** — 允许软删除可见性过滤：
```json
{
  "read": "auth.openid == doc._openid",
  "write": "auth.openid == doc._openid && (doc._id.length === 24 || auth.openid == doc._openid)"
}
```
> 说明：与通用规则相同，应用层负责软删除过滤。

**knowledge_items** — 需确保软删除字段可写：
```json
{
  "read": "auth.openid == doc._openid",
  "write": "auth.openid == doc._openid"
}
```
> 说明：与通用规则相同。`isDeleted` 由应用层在编辑时控制，CloudBase 不支持字段级规则。

**chats** — 需允许按 `updatedAt` 排序：
```json
{
  "read": "auth.openid == doc._openid",
  "write": "auth.openid == doc._openid"
}
```
> 说明：与通用规则相同。排序由应用层查询参数控制。

**messages** — 需支持批量插入（AI 对话流式追加）：
```json
{
  "read": "auth.openid == doc._openid",
  "write": "auth.openid == doc._openid"
}
```
> 说明：与通用规则相同。`messages` 通过 `chatId` 与 `chats` 关联，`_openid` 由 Auth 自动注入保证隔离。

**user_settings** — 额外约束每用户至多 1 条（应用层保证）：
```json
{
  "read": "auth.openid == doc._openid",
  "write": "auth.openid == doc._openid"
}
```
> ⚠️ 应用层约定：创建前先查询 `_openid` 是否已有记录；若有则 update 而非 create。安全规则无法表达唯一约束。

**news_items** — 预备 V2 公开阅读（当前保持私有）：
```json
{
  "read": "auth.openid == doc._openid",
  "write": "auth.openid == doc._openid"
}
```
> V2 后如需"分享资讯"，改为 `"read": true`（登录用户均可读），`"write"` 保持仅创建者可写。

#### B.2.3 安全规则 JSON 模板（CloudBase 控制台导入）

在 CloudBase 控制台「数据库 → 安全规则」中，逐集合粘贴：

```json
{
  "goals":            { "read": "auth.openid == doc._openid", "write": "auth.openid == doc._openid" },
  "milestones":       { "read": "auth.openid == doc._openid", "write": "auth.openid == doc._openid" },
  "tasks":            { "read": "auth.openid == doc._openid", "write": "auth.openid == doc._openid" },
  "categories":       { "read": "auth.openid == doc._openid", "write": "auth.openid == doc._openid" },
  "knowledge_items":  { "read": "auth.openid == doc._openid", "write": "auth.openid == doc._openid" },
  "chats":            { "read": "auth.openid == doc._openid", "write": "auth.openid == doc._openid" },
  "messages":         { "read": "auth.openid == doc._openid", "write": "auth.openid == doc._openid" },
  "review_cards":     { "read": "auth.openid == doc._openid", "write": "auth.openid == doc._openid" },
  "review_history":   { "read": "auth.openid == doc._openid", "write": "auth.openid == doc._openid" },
  "output_docs":      { "read": "auth.openid == doc._openid", "write": "auth.openid == doc._openid" },
  "user_settings":    { "read": "auth.openid == doc._openid", "write": "auth.openid == doc._openid" },
  "scraps":           { "read": "auth.openid == doc._openid", "write": "auth.openid == doc._openid" },
  "news_items":       { "read": "auth.openid == doc._openid", "write": "auth.openid == doc._openid" }
}
```

### B.3 数据生命周期规则

#### B.3.1 软删除清理策略

| 集合 | 标记字段 | 清理时机 | 清理方式 |
|------|---------|----------|---------|
| knowledge_items | `isDeleted = true` | 标记后 **90 天** | 云函数定时任务物理删除 |
| goals | `status = 'archived'` | 归档后 **365 天** | 云函数定时任务物理删除 + 级联删除 milestones/tasks |
| chats | — | 永不自动删除 | 用户手动删除，前端二次确认 |
| review_history | — | 保留全部 | 用于统计和算法优化，不删除 |
| news_items | — | 用户手动删除 | 前端提供批量删除已读资讯 |
| scraps | `status = 'archived'` | 归档后 **180 天** | 云函数定时任务物理删除 |

#### B.3.2 定时清理云函数

```js
// cloudfunctions/data-cleanup/index.js
const tcb = require('@cloudbase/node-sdk');
const app = tcb.init({ env: tcb.SYMBOL_CURRENT_ENV });
const db = app.database();
const _ = db.command;

exports.main = async (event, context) => {
  const now = new Date();
  const results = {};

  // 1. 清理标记超过 90 天的已删除知识条目
  const ki90d = new Date(now.getTime() - 90 * 24 * 3600 * 1000);
  const kiRes = await db.collection('knowledge_items')
    .where({ isDeleted: true, updatedAt: _.lt(ki90d) })
    .remove();
  results.knowledge_items_deleted = kiRes.deleted || 0;

  // 2. 清理归档超过 365 天的目标（+ 级联子实体）
  const g365d = new Date(now.getTime() - 365 * 24 * 3600 * 1000);
  const oldGoals = await db.collection('goals')
    .where({ status: 'archived', updatedAt: _.lt(g365d) })
    .get();
  for (const goal of oldGoals.data) {
    await db.collection('tasks').where({ goalId: goal._id }).remove();
    await db.collection('milestones').where({ goalId: goal._id }).remove();
    await db.collection('goals').doc(goal._id).remove();
  }
  results.goals_archived_deleted = oldGoals.data.length;

  // 3. 清理归档超过 180 天的碎片
  const s180d = new Date(now.getTime() - 180 * 24 * 3600 * 1000);
  const scrapRes = await db.collection('scraps')
    .where({ status: 'archived', updatedAt: _.lt(s180d) })
    .remove();
  results.scraps_deleted = scrapRes.deleted || 0;

  console.log('清理完成:', JSON.stringify(results));
  return results;
};
```

#### B.3.3 定时触发配置

在 CloudBase 控制台「云函数 → data-cleanup → 触发器」中创建定时触发器：

| 配置项 | 值 |
|--------|-----|
| 触发方式 | 定时触发 |
| Cron 表达式 | `0 3 * * 0`（每周日凌晨 3:00） |
| 说明 | 低频清理，避免影响日常读写性能 |

### B.4 CloudBase 初始化脚本

一站式初始化脚本，在 CloudBase 环境创建后执行。

```bash
#!/bin/bash
# scripts/init-cloudbase.sh
# StudyMind CloudBase 环境初始化

ENV_ID="$1"
if [ -z "$ENV_ID" ]; then
  echo "用法: ./init-cloudbase.sh <env-id>"
  echo "示例: ./init-cloudbase.sh studymind-xxx"
  exit 1
fi

echo "=== StudyMind CloudBase 初始化 ==="
echo "环境: $ENV_ID"
echo ""

# ---- 1. 确认环境存在 ----
echo "[1/6] 检查 CloudBase 环境..."
tcb env list 2>/dev/null || {
  echo "请先安装 CloudBase CLI: npm i -g @cloudbase/cli"
  echo "然后登录: tcb login"
  exit 1
}

# ---- 2. 创建 13 个集合 ----
echo "[2/6] 创建集合..."
COLLECTIONS=(
  goals milestones tasks categories knowledge_items
  chats messages review_cards review_history
  output_docs user_settings scraps news_items
)
for coll in "${COLLECTIONS[@]}"; do
  tcb db createCollection "$coll" -e "$ENV_ID" 2>/dev/null
  echo "  $coll"
done
echo "  共 13 个集合"

# ---- 3. 创建索引 ----
echo "[3/6] 创建索引..."
node scripts/create-indexes.js "$ENV_ID"
echo "  索引创建完成"

# ---- 4. 配置安全规则 ----
echo "[4/6] 配置安全规则..."
tcb db setSecurityRule -e "$ENV_ID" -f configs/security-rules.json
echo "  安全规则已部署"

# ---- 5. 部署云函数 ----
echo "[5/6] 部署云函数..."
tcb fn deploy ai-proxy -e "$ENV_ID"
tcb fn deploy data-cleanup -e "$ENV_ID"
echo "  ai-proxy + data-cleanup 已部署"

# ---- 6. 配置环境变量 ----
echo "[6/6] 配置云函数环境变量..."
tcb fn config update ai-proxy -e "$ENV_ID" \
  --env-variables "AI_MIMO_KEY=<your-key>,AI_SILICONFLOW_KEY=<your-key>,AI_DOUBAO_KEY=<your-key>"
echo "  环境变量已配置（请替换 <your-key> 为真实 Key）"

echo ""
echo "=== 初始化完成 ==="
echo "下一步:"
echo "  1. 在 CloudBase 控制台确认 13 个集合已创建"
echo "  2. 手动替换 ai-proxy 环境变量中的真实 API Key"
echo "  3. 部署前端静态文件到静态托管"
echo "  4. 开启匿名登录（控制台 → 登录授权 → 匿名登录）"
```

**依赖文件**：`configs/security-rules.json`（内容见 B.2.3）。

### B.5 部署检查清单

在每次部署前逐项确认。

#### B.5.1 CloudBase 控制台检查

| # | 检查项 | 确认位置 | V1 | V1.5 | V2 |
|:--:|------|------|:--:|:--:|:--:|
| 1 | 13 个集合已创建 | 数据库 → 集合列表 | ☐ | ☐ | ☐ |
| 2 | 所有索引已创建（见 B.1） | 数据库 → 集合 → 索引管理 | ☐ | ☐ | ☐ |
| 3 | 安全规则已逐集合配置（见 B.2.3） | 数据库 → 安全规则 | ☐ | ☐ | ☐ |
| 4 | ai-proxy 云函数已部署 | 云函数 → 列表 | ☐ | ☐ | ☐ |
| 5 | data-cleanup 云函数已部署 + 定时触发器已配置 | 云函数 → 列表 → 触发器 | ☐ | ☐ | ☐ |
| 6 | ai-proxy 环境变量已填写（3 个 Key） | 云函数 → ai-proxy → 环境变量 | ☐ | ☐ | ☐ |
| 7 | 匿名登录已开启 | 登录授权 → 匿名登录 | ☐ | ☐ | ☐ |
| 8 | 静态托管域名可访问 | 静态网站托管 → 默认域名 | ☐ | ☐ | ☐ |
| 9 | CSP 策略已配置（§11.5） | 静态网站托管 → 域名管理 | — | — | ☐ |

#### B.5.2 前端代码检查

| # | 检查项 | 验证方法 | V1 | V1.5 | V2 |
|:--:|------|------|:--:|:--:|:--:|
| A | `cloudbase.js` 中 envId 正确 | 搜索 `env:` 确认 | ☐ | ☐ | ☐ |
| B | 无硬编码 API Key | 搜索 `sk-` `mimo-` `Bearer` 确认 | ☐ | ☐ | ☐ |
| C | 所有 CloudBase 调用走 SDK | 搜索 `fetch(` 确认无不安全直连 | ☐ | ☐ | ☐ |
| D | CSP meta 标签配置正确 | 查看 index.html `<head>` | — | — | ☐ |
| E | 侧边栏 7 项导航完整 | 打开首页目视检查 | ☐ | ☐ | ☐ |
| F | 白色主题 CSS 变量一致 | 打开 3 个页面确认无暗色泄漏 | ☐ | ☐ | ☐ |

